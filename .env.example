# ─────────────────────────────────────────────────────────────────────────────
# AAOS — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://aaos:changeme@localhost:5432/aaos?schema=public"
# Direct (non-pooled) connection for migrations
DIRECT_URL="postgresql://aaos:changeme@localhost:5432/aaos?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────────
# Used by BullMQ workers
REDIS_URL="redis://localhost:6379"

# ── Clerk (Auth) ─────────────────────────────────────────────────────────────
# https://dashboard.clerk.com — create a new application
CLERK_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Webhook secret for Clerk events (user.created, organization.created, etc.)
CLERK_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used for AI reply generation in conversations
OPENAI_API_KEY="sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Default model — gpt-4o-mini for cost efficiency, gpt-4o for best quality
OPENAI_MODEL="gpt-4o-mini"

# ── Telnyx (SMS) ─────────────────────────────────────────────────────────────
# https://portal.telnyx.com
TELNYX_API_KEY="KEY01XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Public key for webhook signature verification
TELNYX_PUBLIC_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Messaging profile ID from Telnyx portal
TELNYX_MESSAGING_PROFILE_ID="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# ── Resend (Email) ────────────────────────────────────────────────────────────
# https://resend.com
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Default "From" address — must be verified in Resend
EMAIL_FROM="Apex Agency <noreply@yourdomain.com>"

# ── Stripe (Billing) ──────────────────────────────────────────────────────────
# https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Webhook secret — from `stripe listen --forward-to ...` or Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Stripe Price IDs for subscription plans
STRIPE_PRICE_STARTER="price_XXXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_GROWTH="price_XXXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_SCALE="price_XXXXXXXXXXXXXXXXXXXXXX"

# ── AWS S3 (File Storage) ─────────────────────────────────────────────────────
# Used for logo uploads, document attachments, etc.
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_REGION="us-east-1"
S3_BUCKET="aaos-uploads"

# ── App URLs ──────────────────────────────────────────────────────────────────
# Internal API base (used by Next.js server components to call the Fastify API)
API_URL="http://localhost:3001"
# Public app URL (agency dashboard)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public client portal URL
NEXT_PUBLIC_CLIENT_URL="http://localhost:3002"

# ── Misc ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"
