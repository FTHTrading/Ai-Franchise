// This is the main Prisma schema for AAOS — AI Automation Agency OS
// Multi-tenant, white-label SaaS platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORGANIZATION_OWNER
  ORGANIZATION_ADMIN
  OPERATOR
  CLIENT_ADMIN
  CLIENT_USER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  WON
  LOST
  UNSUBSCRIBED
}

enum LeadSource {
  WEBSITE_FORM
  LANDING_PAGE
  MANUAL
  IMPORT
  REFERRAL
  GOOGLE_ADS
  FACEBOOK_ADS
  MISSED_CALL
  SMS_INBOUND
  OTHER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  SMS
  EMAIL
  CHAT
  VOICE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
  OPTED_OUT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowTriggerType {
  NEW_LEAD
  FORM_SUBMITTED
  MISSED_CALL
  INBOUND_SMS
  NO_RESPONSE
  APPOINTMENT_REMINDER
  STATUS_CHANGED
  TAG_ADDED
  MANUAL
  SCHEDULED
  WEBHOOK
}

enum WorkflowActionType {
  SEND_SMS
  SEND_EMAIL
  GENERATE_AI_MESSAGE
  ASSIGN_LEAD
  UPDATE_STAGE
  ADD_TAG
  REMOVE_TAG
  CREATE_TASK
  CALL_WEBHOOK
  WAIT_DELAY
  NOTIFY_OPERATOR
  BOOK_APPOINTMENT
  UPDATE_FIELD
  BRANCH_CONDITION
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  PAUSED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
}

enum IntegrationProvider {
  TELNYX
  TWILIO
  RESEND
  SENDGRID
  STRIPE
  CALENDLY
  GOOGLE_CALENDAR
  ACUITY
  ZAPIER
  S3
  CLOUDFLARE_R2
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE
  REVOKE
  PUBLISH
  ARCHIVE
  EXECUTE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum TemplateCategory {
  MISSED_CALL_TEXTBACK
  LEAD_FOLLOWUP
  APPOINTMENT_REMINDER
  REACTIVATION
  FAQ_ASSISTANT
  INTAKE_QUALIFICATION
  ESTIMATE_FOLLOWUP
  REVIEW_REQUEST
  WELCOME_SEQUENCE
  NURTURE_SEQUENCE
  CUSTOM
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  firstName     String?
  lastName      String?
  avatarUrl     String?
  phone         String?
  timezone      String   @default("America/New_York")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  organizationMemberships OrganizationMembership[]
  clientMemberships       ClientMembership[]
  assignedLeads           Lead[]                   @relation("AssignedLeads")
  sentMessages            Message[]                @relation("SentMessages")
  createdTasks            Task[]                   @relation("CreatedTasks")
  assignedTasks           Task[]                   @relation("AssignedTasks")
  notifications           Notification[]
  auditLogs               AuditLog[]

  @@index([email])
  @@index([clerkId])
}

// ─────────────────────────────────────────────
// ORGANIZATION (AGENCY TENANT)
// ─────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  clerkOrgId  String?  @unique
  domains     String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  memberships     OrganizationMembership[]
  clientAccounts  ClientAccount[]
  leads           Lead[]
  conversations   Conversation[]
  appointments    Appointment[]
  brandSettings   BrandSettings?
  subscription    Subscription?
  billingAccount  BillingAccount?
  workflows       Workflow[]
  templates       Template[]
  campaigns       Campaign[]
  integrations    ConnectedIntegration[]
  webhookEvents   WebhookEvent[]
  auditLogs       AuditLog[]
  usageLogs       UsageLog[]
  notifications   Notification[]
  fileAssets      FileAsset[]
  onboardingState OnboardingState?

  @@index([slug])
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole @default(OPERATOR)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// CLIENT ACCOUNT (AGENCY'S CUSTOMER)
// ─────────────────────────────────────────────

model ClientAccount {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  businessType   String?
  industry       String?
  website        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  country        String   @default("US")
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     ClientMembership[]
  leads           Lead[]
  conversations   Conversation[]
  appointments    Appointment[]
  tasks           Task[]
  workflows       WorkflowAssignment[]
  brandSettings   ClientBrandSettings?
  billingRecord   ClientBillingRecord?
  integrations    ConnectedIntegration[]
  channels        CommunicationChannel[]
  auditLogs       AuditLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model ClientMembership {
  id              String   @id @default(cuid())
  userId          String
  clientAccountId String
  role            UserRole @default(CLIENT_USER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, clientAccountId])
  @@index([clientAccountId])
}

// ─────────────────────────────────────────────
// LEAD + CRM
// ─────────────────────────────────────────────

model Lead {
  id              String     @id @default(cuid())
  organizationId  String
  clientAccountId String
  assignedUserId  String?

  firstName     String
  lastName      String?
  email         String?
  phone         String?
  status        LeadStatus @default(NEW)
  source        LeadSource @default(OTHER)
  sourceDetail  String?
  stage         String     @default("New")
  value         Float?
  optedOut      Boolean    @default(false)
  qualifiedAt   DateTime?
  bookedAt      DateTime?
  wonAt         DateTime?
  lostAt        DateTime?
  lostReason    String?
  lastContactAt DateTime?
  nextFollowUpAt DateTime?

  customFields     Json    @default("{}")
  metadata         Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  assignedUser  User?         @relation("AssignedLeads", fields: [assignedUserId], references: [id])

  notes         LeadNote[]
  tags          LeadTag[]
  conversations Conversation[]
  appointments  Appointment[]
  tasks         Task[]
  executions    WorkflowExecution[]
  auditLogs     AuditLog[]

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([assignedUserId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String?
  content   String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model LeadTag {
  id     String @id @default(cuid())
  leadId String
  tag    String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, tag])
  @@index([leadId])
  @@index([tag])
}

// ─────────────────────────────────────────────
// COMMUNICATION HUB
// ─────────────────────────────────────────────

model CommunicationChannel {
  id              String             @id @default(cuid())
  organizationId  String
  clientAccountId String?
  provider        String
  channel         MessageChannel
  name            String
  identifier      String             // phone number or email address
  isDefault       Boolean            @default(false)
  isActive        Boolean            @default(true)
  config          Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  clientAccount ClientAccount? @relation(fields: [clientAccountId], references: [id])
  conversations Conversation[]
  messages      Message[]

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([identifier])
}

model Conversation {
  id              String   @id @default(cuid())
  organizationId  String
  clientAccountId String
  leadId          String?
  channelId       String?

  channel       MessageChannel
  direction     MessageDirection @default(INBOUND)
  subject       String?
  isOpen        Boolean          @default(true)
  isRead        Boolean          @default(false)
  lastMessageAt DateTime?
  aiEnabled     Boolean          @default(true)
  resolvedAt    DateTime?
  resolvedBy    String?

  metadata  Json @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccount   ClientAccount        @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  lead            Lead?                @relation(fields: [leadId], references: [id])
  channel_record  CommunicationChannel? @relation(fields: [channelId], references: [id])
  messages        Message[]

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([leadId])
  @@index([isOpen])
  @@index([lastMessageAt])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  channelId      String?
  senderId       String?
  direction      MessageDirection
  channel        MessageChannel
  status         MessageStatus    @default(PENDING)
  body           String
  subject        String?
  mediaUrls      String[]         @default([])
  isAiGenerated  Boolean          @default(false)
  externalId     String?          // Telnyx/Resend message ID
  deliveredAt    DateTime?
  readAt         DateTime?
  failureReason  String?
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  channel_record CommunicationChannel? @relation(fields: [channelId], references: [id])
  sender         User?                @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────

model Appointment {
  id              String            @id @default(cuid())
  organizationId  String
  clientAccountId String
  leadId          String?

  title         String
  description   String?
  status        AppointmentStatus @default(SCHEDULED)
  startAt       DateTime
  endAt         DateTime
  timezone      String            @default("America/New_York")
  location      String?
  meetingUrl    String?
  value         Float?
  notes         String?
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  reminderSentAt DateTime?
  externalId    String?

  metadata  Json @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  lead          Lead?         @relation(fields: [leadId], references: [id])

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([leadId])
  @@index([startAt])
  @@index([status])
}

// ─────────────────────────────────────────────
// WORKFLOW ENGINE
// ─────────────────────────────────────────────

model Workflow {
  id             String              @id @default(cuid())
  organizationId String
  clientAccountId String?
  templateId     String?
  name           String
  description    String?
  status         WorkflowStatus      @default(DRAFT)
  triggerType    WorkflowTriggerType
  triggerConfig  Json                @default("{}")
  steps          Json                // Array of WorkflowStep definitions
  settings       Json                @default("{}")
  niche          String?
  tags           String[]            @default([])
  version        Int                 @default(1)
  publishedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template      Template?          @relation(fields: [templateId], references: [id])
  executions    WorkflowExecution[]
  assignments   WorkflowAssignment[]
  versions      WorkflowVersion[]

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([status])
  @@index([triggerType])
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  steps      Json
  settings   Json     @default("{}")
  note       String?
  createdBy  String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowAssignment {
  id              String   @id @default(cuid())
  workflowId      String
  clientAccountId String
  isActive        Boolean  @default(true)
  config          Json     @default("{}")
  activatedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow      Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@unique([workflowId, clientAccountId])
  @@index([clientAccountId])
}

model WorkflowExecution {
  id             String          @id @default(cuid())
  workflowId     String
  organizationId String
  leadId         String?
  triggeredBy    String          // event type that triggered it
  triggerData    Json            @default("{}")
  status         ExecutionStatus @default(PENDING)
  currentStep    Int             @default(0)
  completedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  duration       Int?            // ms
  retryCount     Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workflow Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lead     Lead?                   @relation(fields: [leadId], references: [id])
  steps    WorkflowExecutionStep[]

  @@index([workflowId])
  @@index([organizationId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowExecutionStep {
  id          String          @id @default(cuid())
  executionId String
  stepIndex   Int
  actionType  WorkflowActionType
  input       Json            @default("{}")
  output      Json            @default("{}")
  status      ExecutionStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  error       String?
  duration    Int?            // ms

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

// ─────────────────────────────────────────────
// TEMPLATES
// ─────────────────────────────────────────────

model Template {
  id             String           @id @default(cuid())
  organizationId String?          // null = global/system template
  name           String
  description    String?
  category       TemplateCategory
  triggerType    WorkflowTriggerType
  steps          Json             // workflow steps definition
  prompts        Json             @default("{}")     // editable AI prompts keyed by step
  variables      Json             @default("[]")     // {key, label, defaultValue, required}
  niche          String[]         @default([])       // applicable niches
  tags           String[]         @default([])
  previewText    String?          // plain-English summary
  isPublic       Boolean          @default(false)    // visible in global library
  isSystem       Boolean          @default(false)    // system-provided default
  installCount   Int              @default(0)
  version        String           @default("1.0")
  thumbnailUrl   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id])
  workflows    Workflow[]

  @@index([organizationId])
  @@index([category])
  @@index([isPublic])
  @@index([isSystem])
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────

model Campaign {
  id              String         @id @default(cuid())
  organizationId  String
  clientAccountId String?
  name            String
  description     String?
  status          CampaignStatus @default(DRAFT)
  channel         MessageChannel
  audienceConfig  Json           @default("{}")  // filters for lead selection
  messageTemplate String
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  sentCount       Int            @default(0)
  deliveredCount  Int            @default(0)
  failedCount     Int            @default(0)
  replyCount      Int            @default(0)
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([status])
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────

model Task {
  id              String       @id @default(cuid())
  organizationId  String
  clientAccountId String?
  leadId          String?
  createdById     String?
  assignedToId    String?
  title           String
  description     String?
  status          TaskStatus   @default(OPEN)
  priority        TaskPriority @default(MEDIUM)
  dueAt           DateTime?
  completedAt     DateTime?
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  clientAccount ClientAccount? @relation(fields: [clientAccountId], references: [id])
  lead          Lead?          @relation(fields: [leadId], references: [id])
  createdBy     User?          @relation("CreatedTasks", fields: [createdById], references: [id])
  assignedTo    User?          @relation("AssignedTasks", fields: [assignedToId], references: [id])

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  title          String
  body           String
  type           String   // lead_created, message_received, workflow_failed, etc.
  entityType     String?
  entityId       String?
  isRead         Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([isRead])
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String             @unique
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  tier             SubscriptionTier   @default(STARTER)
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean          @default(false)
  cancelledAt      DateTime?
  trialEndsAt      DateTime?
  planId           String?
  quantity         Int                @default(1)
  mrr              Float              @default(0)       // monthly recurring revenue in cents
  metadata         Json               @default("{}")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     InvoiceRecord[]

  @@index([stripeCustomerId])
  @@index([stripeSubId])
  @@index([status])
}

model BillingAccount {
  id             String   @id @default(cuid())
  organizationId String   @unique
  stripeId       String?  @unique
  email          String?
  name           String?
  address        Json     @default("{}")
  taxId          String?
  currency       String   @default("usd")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model InvoiceRecord {
  id             String   @id @default(cuid())
  organizationId String
  subscriptionId String?
  stripeInvoiceId String?  @unique
  amount         Float
  currency       String   @default("usd")
  status         String   // paid, open, void, uncollectible
  description    String?
  paidAt         DateTime?
  dueAt          DateTime?
  hostedUrl      String?
  pdfUrl         String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId])
  @@index([subscriptionId])
}

model ClientBillingRecord {
  id              String   @id @default(cuid())
  clientAccountId String   @unique
  organizationId  String
  servicePlan     String?
  monthlyFee      Float    @default(0)
  setupFee        Float    @default(0)
  billingStatus   String   @default("active")
  nextBillingDate DateTime?
  internalNotes   String?
  contractStart   DateTime?
  contractEnd     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─────────────────────────────────────────────
// BRAND & WHITE-LABEL
// ─────────────────────────────────────────────

model BrandSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  brandName      String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#6366f1")
  secondaryColor String   @default("#8b5cf6")
  accentColor    String   @default("#06b6d4")
  textColor      String   @default("#0f172a")
  bgColor        String   @default("#ffffff")
  darkMode       Boolean  @default(false)
  fontFamily     String   @default("Inter")
  customDomain   String?
  emailFromName  String?
  emailFromAddr  String?
  supportEmail   String?
  footerText     String?
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ClientBrandSettings {
  id              String   @id @default(cuid())
  clientAccountId String   @unique
  brandName       String?
  logoUrl         String?
  primaryColor    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// INTEGRATIONS
// ─────────────────────────────────────────────

model ConnectedIntegration {
  id              String            @id @default(cuid())
  organizationId  String
  clientAccountId String?
  provider        IntegrationProvider
  status          IntegrationStatus @default(DISCONNECTED)
  label           String?
  config          Json              @default("{}")  // encrypted at app level before storing
  scopes          String[]          @default([])
  externalId      String?
  expiresAt       DateTime?
  lastSyncAt      DateTime?
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount? @relation(fields: [clientAccountId], references: [id])

  @@unique([organizationId, provider, clientAccountId])
  @@index([organizationId])
  @@index([clientAccountId])
}

// ─────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────

model WebhookEvent {
  id             String             @id @default(cuid())
  organizationId String?
  provider       String             // stripe, telnyx, resend, etc.
  eventType      String
  externalId     String?            @unique  // provider's event ID for idempotency
  payload        Json
  status         WebhookEventStatus @default(RECEIVED)
  processedAt    DateTime?
  failureReason  String?
  retryCount     Int                @default(0)
  createdAt      DateTime           @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([provider])
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// OBSERVABILITY
// ─────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String?
  clientAccountId String?
  userId         String?
  leadId         String?
  action         AuditAction
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ip             String?
  userAgent      String?
  correlationId  String?
  createdAt      DateTime    @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  clientAccount ClientAccount? @relation(fields: [clientAccountId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  lead         Lead?         @relation(fields: [leadId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model UsageLog {
  id             String   @id @default(cuid())
  organizationId String
  clientAccountId String?
  category       String   // sms_sent, email_sent, ai_query, workflow_execution
  quantity       Int      @default(1)
  metadata       Json     @default("{}")
  billedAt       DateTime?
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientAccountId])
  @@index([category])
  @@index([periodStart, periodEnd])
}

// ─────────────────────────────────────────────
// FILE ASSETS
// ─────────────────────────────────────────────

model FileAsset {
  id             String   @id @default(cuid())
  organizationId String
  uploadedById   String?
  filename       String
  contentType    String
  size           Int
  url            String
  bucket         String
  key            String
  purpose        String?  // logo, avatar, import, attachment, etc.
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─────────────────────────────────────────────
// ONBOARDING
// ─────────────────────────────────────────────

model OnboardingState {
  id             String   @id @default(cuid())
  organizationId String   @unique
  completedSteps Json     @default("[]")  // ["brand", "channel", "template", "client", "team"]
  currentStep    String   @default("brand")
  isComplete     Boolean  @default(false)
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
